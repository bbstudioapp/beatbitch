<?xml version="1.0" encoding="utf-8"?>
<!--
    Bloque entièrement la sauvegarde cloud (Auto Backup) et le transfert
    appareil-à-appareil (D2D) pour Android 12+ (API 31+). Couplé à
    android:allowBackup="false" du manifest pour les API antérieures.
    Les SharedPreferences (scores, milestones, profils) ne sortent jamais
    du téléphone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
