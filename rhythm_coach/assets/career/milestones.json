        {"time": 42, "text": "Respire, mais garde ta gorge ouverte et ta langue dehors.", "mode": "beg", "duration": 8},
        {"time": 50, "text": "Supplie-moi de rester là.", "mode": "beg", "to": "throat", "duration": 10},
        {"time": 60, "text": "Bonne petite.", "mode": "breath", "duration": 5}
