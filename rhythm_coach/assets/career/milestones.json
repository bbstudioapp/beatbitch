      "branches": ["obeissance", "profondeur"],
      "sequence": [
        {"time": 0,  "text": "Ouvre la bouche bien grande, tire la langue. Je veux voir ta gorge ouverte pour moi.", "mode": "beg", "duration": 10},
        {"time": 10, "text": "Demande-moi de te l'enfoncer plus.", "mode": "beg", "to": "mid", "duration": 8},
        {"time": 18, "text": "Tu veux que je reste comme ça ? Réponds-moi.", "mode": "beg", "to": "throat", "duration": 10},
