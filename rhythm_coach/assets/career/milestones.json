        {"time": 18, "text": "Respire bien.", "mode": "breath", "duration": 10},
        {"time": 28, "text": "Maintenant dix secondes.", "mode": "hold", "to": "full", "duration": 10},
        {"time": 38, "text": "Bien fait. Lèche pour récupérer.", "mode": "lick", "from": "head", "to": "mid", "bpm": 80, "duration": 12}
      ]
    },
