        {"axis": "rhythm.motion_streak", "min": 30}
      ],
      "sequence": [
        {"time": 0,  "text": "Là tu fais ce que tu veux. Trente secondes pour me montrer.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 100, "duration": 8},
        {"time": 8,  "text": "Vas-y. Surprends-moi.", "mode": "freestyle", "duration": 30},
        {"time": 38, "text": "Bien fait. Termine doucement.", "mode": "lick", "from": "head", "to": "mid", "bpm": 80, "duration": 10}
      ]
    },
    {
