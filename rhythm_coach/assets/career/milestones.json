        {"time": 18, "text": "Respire.", "mode": "breath", "duration": 8},
        {"time": 26, "text": "Maintenant huit secondes.", "mode": "hold", "to": "throat", "duration": 8},
        {"time": 34, "text": "Très bien. Lèche pour récupérer.", "mode": "lick", "from": "head", "to": "mid", "bpm": 80, "duration": 12}
      ]
    },
    {
