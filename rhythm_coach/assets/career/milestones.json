        {"time": 10, "text": "Coups rapides. Tiens bon.", "mode": "biffle", "bpm": 140, "duration": 15},
        {"time": 25, "text": "Respire.", "mode": "breath", "duration": 10},
        {"time": 35, "text": "Lèche pour finir.", "mode": "lick", "from": "head", "to": "mid", "bpm": 80, "duration": 10}
