        {"time": 11, "text": "Respire.", "mode": "breath", "duration": 6},
        {"time": 17, "text": "Encore une. Lentement.", "mode": "rhythm", "from": "head", "to": "throat", "bpm": 75, "duration": 3},
        {"time": 20, "text": "Reprends ton souffle.", "mode": "breath", "duration": 6},
        {"time": 26, "text": "Dernière. Tu y es.", "mode": "rhythm", "from": "head", "to": "throat", "bpm": 75, "duration": 3},
        {"time": 29, "text": "Respire profondément.", "mode": "breath", "duration": 8},
        {"time": 37, "text": "Lèche pour finir, doucement.", "mode": "lick", "from": "head", "to": "mid", "bpm": 75, "duration": 10}
      ]
    },
