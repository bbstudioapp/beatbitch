        {"time": 12, "text": "Respire bien.", "mode": "breath", "duration": 8},
        {"time": 20, "text": "Encore, plus longtemps. Trois secondes.", "mode": "hold", "to": "throat", "duration": 3},
        {"time": 23, "text": "Bien. Repose-toi.", "mode": "lick", "from": "head", "to": "mid", "bpm": 80, "duration": 10}
