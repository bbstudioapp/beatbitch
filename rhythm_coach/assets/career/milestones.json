{
  "lang": "fr",
  "milestones": [
    {
      "id": "intro_basics",
      "level": 1,
      "displayLabel": "Première séance — apprends les bases",
      "unlocks": [
        "basics"
      ],
      "requires": [],
      "insertAtMinSeconds": 0,
      "insertAtMaxSeconds": 0,
      "maxRetry": 2,
      "requiresHands": true,
      "sequence": [
        {"time": 0,   "text": "Installe-toi confortablement. Prends-moi dans ta main, et commence par monter… descendre.", "mode": "breath", "duration": 8},
        {"time": 8,   "mode": "hand", "from": "tip", "to": "head", "bpm": 60, "duration": 10},
        {"time": 18,  "text": "C'est très bien. Accélère un peu.", "mode": "hand", "from": "tip", "to": "head", "bpm": 80, "duration": 12},
        {"time": 30,  "text": "Mmm… tu es douce. Mais tu vas devoir faire un peu plus que ça. Pose tes lèvres sur le bout.", "mode": "breath", "duration": 7},
        {"time": 37,  "text": "Comme ça. Reste là.", "mode": "hold", "to": "tip", "duration": 4},
        {"time": 41,  "text": "Sors un peu ta langue pour le lécher.", "mode": "hold", "to": "tip", "duration": 5},
        {"time": 46,  "text": "Très bien. Continue.", "mode": "lick", "from": "tip", "to": "head", "bpm": 60, "duration": 10},
        {"time": 56,  "text": "Arrête-toi. Ouvre ta bouche. Mets-le doucement dedans.", "mode": "hold", "to": "tip", "duration": 6},
        {"time": 62,  "text": "Parfait. Maintenant tu vas commencer à sucer. Tu remontes, tu redescends. Doucement.", "mode": "hold", "to": "head", "duration": 7},
        {"time": 69,  "text": "Tu t'en sors magnifiquement bien. Continue.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 60, "duration": 14},
        {"time": 83,  "text": "Maintenant juste avec ta langue.", "mode": "lick", "from": "tip", "to": "head", "bpm": 65, "duration": 10},
        {"time": 93,  "text": "Reprends-le dans ta bouche, un peu plus vite.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 70, "duration": 14},
        {"time": 107, "text": "Tu peux jouer avec ta langue pendant que tu suces. Tu fais ça très bien.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 75, "duration": 14},
        {"time": 121, "text": "Vas un peu plus vite.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 85, "duration": 12},
        {"time": 133, "text": "C'est bien. Reste-là maintenant. Tu aimes ça ?", "mode": "hold", "to": "head", "duration": 6},
        {"time": 139, "text": "Parfait. On continue.", "mode": "breath", "duration": 4}
      ]
    },
    {
      "id": "intro_deeper_basics",
      "level": 3,
      "displayLabel": "Plus profond — rythme en bouche",
      "unlocks": ["rhythm_mid_basic"],
      "requires": [
        "basics"
      ],
      "branches": ["profondeur", "rythmeBiffle"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui tu prends plus profond. Suce-moi jusqu'au milieu, plus rapide.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 105, "duration": 14},
        {"time": 14, "text": "Continue. Va le chercher au fond.", "mode": "rhythm", "from": "tip", "to": "mid", "bpm": 100, "duration": 12},
        {"time": 26, "text": "Encore. Plus vite.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 115, "duration": 14},
        {"time": 40, "text": "Bien. Reprends ton souffle.", "mode": "breath", "duration": 8}
      ]
    },
    {
      "id": "intro_lick_full",
      "level": 4,
      "displayLabel": "Lèche-moi en entier",
      "unlocks": ["lick_full"],
      "requires": [
        "basics"
      ],
      "branches": ["sloppy"],
      "sequence": [
        {"time": 0,  "text": "Tu vas me lécher en entier aujourd'hui. Du bout jusqu'à la base, langue bien sortie. Lente.", "mode": "lick", "from": "tip", "to": "throat", "bpm": 55, "duration": 22},
        {"time": 22, "text": "Continue. Toute la longueur.", "mode": "lick", "from": "head", "to": "throat", "bpm": 60, "duration": 18},
        {"time": 40, "text": "Respire un peu.", "mode": "breath", "duration": 6},
        {"time": 46, "text": "Recommence. Plus humide.", "mode": "lick", "from": "tip", "to": "throat", "bpm": 65, "duration": 20},
        {"time": 66, "text": "Parfait. Tu peux t'arrêter.", "mode": "breath", "duration": 6}
      ]
    },
    {
      "id": "intro_beg_libre",
      "level": 3,
      "displayLabel": "Première supplique",
      "unlocks": ["beg_libre"],
      "requires": [
        "basics"
      ],
      "branches": ["obeissance"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui tu vas apprendre à supplier. Tu vas répéter exactement ce que je te dis.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 80, "duration": 7},
        {"time": 7, "text": "Répète après moi : « j'aime te faire du bien ».", "mode": "beg", "duration": 7},
        {"time": 14, "text": "Dit : « laisse-moi te faire du bien s’il te plaît ». Dis-le, fort.", "mode": "beg", "duration": 8},
        {"time": 22, "text": "Répète : « pitié, donne-moi ta queue ».", "mode": "beg", "duration": 6},
        {"time": 28, "text": "Vas-y maintenant", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 80, "duration": 6},
        {"time": 34, "text": "Bien. À partir de maintenant, tu peux supplier de toi-même quand tu en veux plus. Le bouton vient d'apparaître à l'écran.", "mode": "lick", "from": "tip", "to": "head", "bpm": 70, "duration": 12}
      ]
    },
    {
      "id": "intro_sloppy_drool",
      "level": 3,
      "displayLabel": "Lèche humide — fais-moi baver",
      "unlocks": ["sloppy_drool_basic"],
      "requires": [
        "basics"
      ],
      "branches": ["sloppy"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui on va salir. Sors la langue, lèche-le bien humide, ne te retiens pas.", "mode": "lick", "from": "tip", "to": "head", "bpm": 75, "duration": 14},
        {"time": 14, "text": "Plus mouillée. Salive partout sur ma queue.", "mode": "lick", "from": "tip", "to": "head", "bpm": 85, "duration": 14},
        {"time": 28, "text": "Reste sur le bout, langue dehors. Bave dessus.", "mode": "hold", "to": "tip", "duration": 6},
        {"time": 34, "text": "Reprends, lent, en faisant déborder.", "mode": "lick", "from": "tip", "to": "head", "bpm": 60, "duration": 12}
      ]
    },
    {
      "id": "intro_sloppy_loud_suck",
      "level": 4,
      "displayLabel": "Fais du bruit, sois sale",
      "unlocks": ["sloppy_loud_suck"],
      "requires": ["sloppy_drool_basic"],
      "branches": ["sloppy"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui je veux t'entendre. Sois bruyante, sois sale, ne te retiens pas. Plus c'est mouillé, plus j'aime.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 75, "duration": 12},
        {"time": 12, "text": "Encore, plus fort. Aspire-le, fais du bruit.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 85, "duration": 12},
        {"time": 24, "text": "Lèche-le bruyamment, que ça claque.", "mode": "lick", "from": "tip", "to": "head", "bpm": 70, "duration": 14},
        {"time": 38, "text": "Reprends-le. Pas de discrétion, je veux t'entendre saliver.", "mode": "rhythm", "from": "tip", "to": "head", "bpm": 80, "duration": 12}
      ]
    },
    {
      "id": "intro_hold_mid",
      "level": 3,
      "displayLabel": "Hold position médiane",
      "unlocks": ["hold_mid_short"],
      "requires": [
        "basics"
      ],
      "branches": ["endurance", "profondeur"],
      "sequence": [
        {"time": 0,  "text": "Plus profond aujourd'hui. Tu vas aller toucher l'entrée de la gorge avec le bout de ma queue. Prends-la loin dans la bouche.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 90, "duration": 12},
        {"time": 12, "text": "Tiens-le là. Deux secondes.", "mode": "hold", "to": "mid", "duration": 3},
        {"time": 15, "text": "Respire. Garde-la profonde.", "mode": "breath", "duration": 6},
        {"time": 21, "text": "Encore. Trois secondes cette fois.", "mode": "hold", "to": "mid", "duration": 4},
        {"time": 25, "text": "Bien. Tu le fais tellement bien qu'on en fait une de plus.", "mode": "breath", "duration": 5},
        {"time": 30, "text": "Dernière. Trois secondes.", "mode": "hold", "to": "mid", "duration": 4},
        {"time": 34, "text": "Bien fait. Lèche.", "mode": "lick", "from": "head", "to": "head", "bpm": 80, "duration": 10}
      ]
    },
    {
      "id": "intro_biffle",
      "level": 5,
      "displayLabel": "Premiers biffles",
      "unlocks": ["biffle_basic"],
      "requires": [
        "basics"
      ],
      "requiresHands": true,
      "branches": ["rythmeBiffle"],
      "sequence": [
        {"time": 0,  "text": "Ouvre la bouche. Tu vas recevoir.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 90, "duration": 8},
        {"time": 8,  "text": "Coups de queue. Reçois-les.", "mode": "biffle", "bpm": 90, "duration": 12},
        {"time": 20, "text": "Bien. Lèche pour finir.", "mode": "lick", "from": "head", "to": "head", "bpm": 70, "duration": 8}
      ]
    },
    {
      "id": "intro_encore",
      "level": 5,
      "displayLabel": "Apprends à en redemander",
      "unlocks": ["encore"],
      "requires": ["biffle_basic"],
      "branches": ["obeissance"],
      "sequence": [
        {"time": 0,  "text": "Tu sais finir une séance. Maintenant tu vas apprendre quelque chose de plus difficile : redemander.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 85, "duration": 10},
        {"time": 10, "text": "À la fin d'une séance, si tu en veux encore, tu peux le demander. Mais il faut le mériter, et le supplier.", "mode": "lick", "from": "head", "to": "head", "bpm": 70, "duration": 10},
        {"time": 20, "text": "Première supplique : dis-moi que tu n'en as pas eu assez.", "mode": "beg", "duration": 12},
        {"time": 32, "text": "Deuxième : promets-moi que tu vas faire mieux la prochaine fois.", "mode": "beg", "duration": 12},
        {"time": 44, "text": "Dernière : implore-moi de te ressortir ma queue.", "mode": "beg", "duration": 12},
        {"time": 56, "text": "Bien. À partir de maintenant, à la fin de chaque séance, tu auras un bouton pour me supplier d'en avoir encore. Utilise-le si tu le mérites.", "mode": "lick", "from": "head", "to": "mid", "bpm": 75, "duration": 12}
      ]
    },
    {
      "id": "intro_sloppy_overflow",
      "level": 5,
      "displayLabel": "Laisse-le déborder",
      "unlocks": ["sloppy_overflow"],
      "requires": ["sloppy_drool_basic"],
      "branches": ["sloppy"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui ça déborde. Lèche longtemps, salive sans ravaler, laisse couler sur ton menton.", "mode": "lick", "from": "tip", "to": "head", "bpm": 60, "duration": 14},
        {"time": 14, "text": "Bouche grande ouverte. Reste sur le bout, laisse couler.", "mode": "hold", "to": "tip", "duration": 8},
        {"time": 22, "text": "Reprends, toujours plus mouillée.", "mode": "lick", "from": "tip", "to": "head", "bpm": 65, "duration": 14},
        {"time": 36, "text": "Reste. Bave dessus, étale tout du long.", "mode": "hold", "to": "tip", "duration": 8},
        {"time": 44, "text": "Lèche pour ramasser ce qui a coulé sur ton menton.", "mode": "lick", "from": "tip", "to": "head", "bpm": 55, "duration": 12}
      ]
    },
    {
      "id": "intro_rhythm_sustained",
      "level": 3,
      "displayLabel": "Rythme soutenu — tiens la cadence",
      "unlocks": ["rhythm_head_mid_sustained"],
      "requires": [
        "basics"
      ],
      "requiresCapability": [
        {"axis": "rhythm.motion_streak", "min": 20}
      ],
      "branches": ["rythmeBiffle"],
      "sequence": [
        {"time": 0,  "text": "Aujourd'hui tu vas apprendre à tenir une cadence longue. Échauffe doucement.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 80, "duration": 12},
        {"time": 12, "text": "Petit souffle, prépare-toi. Ce qui vient est long.", "mode": "breath", "duration": 6},
        {"time": 18, "text": "Maintenant tu vas pomper sans t'arrêter, plus d'une minute. Pas de pauses. Tiens la cadence jusqu'au bout.", "mode": "rhythm", "from": "head", "to": "mid", "bpm": 90, "duration": 70},
        {"time": 88, "text": "Tu as tenu, sans casser. Reprends ton souffle.", "mode": "breath", "duration": 12}
      ]
    },
